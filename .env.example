# 管理页创建的 api_key（末端唯一必须配的一项）
KQ_POOL_API_KEY=

# 可选：Aidun 根 URL，默认内置 http://c.aidunkouqiang.com
# 仅在对端域名/协议临时变化时设置（勿尾斜杠）
# KQ_POOL_BASE_URL=http://c.aidunkouqiang.com

# 可选：实例代号（与凭证一致时建议设置，会作为 X-Kq-Pool-Instance-Id 头发出）
# KQ_POOL_INSTANCE_ID=

# 可选：轮询间隔（秒），默认 5
# KQ_POOL_POLL_INTERVAL_SEC=5

# 可选：每次 pull 条数上限，默认 10
# KQ_POOL_PULL_LIMIT=10

# 可选：本地 JSON 落盘目录，默认 data/pending
# KQ_POOL_LOCAL_POOL_DIR=data/pending

# 可选：HTTP 超时（秒），默认 60
# KQ_POOL_HTTP_TIMEOUT_SEC=60

# === 可选：新任务到达即时通知本机 Agent (webhook hook) ===
# 设置后，守护每写完一条任务文件，会再 POST 整条记录给这个 URL。
# 典型搭配：本机跑 hermes gateway + `hermes webhook subscribe bridge-task`，
# 然后把 hermes 给你的 URL 填这里。默认禁用（不设就是老行为）。
# KQ_POOL_NOTIFY_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/bridge-task

# 可选：webhook HMAC 签名 secret。
# - 留空：不签名（仅适合 webhook 也不要求签名时）。
# - 设成 INSECURE_NO_AUTH：显式标注"接收方按 loopback 跳过校验"，仍不签名。
# - 设成实际密钥：与接收方约定的同一个 secret，将以 X-Hub-Signature-256 头发出。
# KQ_POOL_NOTIFY_WEBHOOK_SECRET=

# 可选：通知 POST 超时（秒），默认 5
# KQ_POOL_NOTIFY_WEBHOOK_TIMEOUT_SEC=5
