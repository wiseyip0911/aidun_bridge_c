# Aidun 根 URL，勿尾斜杠
KQ_POOL_BASE_URL=https://example.com

# 管理页创建的 api_key
KQ_POOL_API_KEY=

# 可选；与凭证 instance_id 一致时建议设置（请求头 X-Kq-Pool-Instance-Id）
KQ_POOL_INSTANCE_ID=

# 轮询间隔（秒），默认 5（与誉佳 BridgeC 一致）
# KQ_POOL_POLL_INTERVAL_SEC=5

# 每次 pull 条数上限，默认 10
# KQ_POOL_PULL_LIMIT=10

# 本地 JSON 落盘目录，默认 data/pending
# KQ_POOL_LOCAL_POOL_DIR=data/pending

# HTTP 超时（秒），默认 60
# KQ_POOL_HTTP_TIMEOUT_SEC=60
